{
  "version": 2,
  "builds": [
    {
      "src": "api/send.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.png",
      "use": "@vercel/static"
    },
    {
      "src": "*.pdf",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/send",
      "dest": "/api/send.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
